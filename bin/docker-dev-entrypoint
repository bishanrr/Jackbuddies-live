#!/usr/bin/env bash
set -euo pipefail

cd /rails

bundle check || bundle install
npm install

if [[ -n "${DB_HOST:-}" ]]; then
  until pg_isready -h "$DB_HOST" -p "${DB_PORT:-5432}" -U "${DB_USER:-postgres}" >/dev/null 2>&1; do
    echo "Waiting for PostgreSQL at ${DB_HOST}:${DB_PORT:-5432}..."
    sleep 1
  done
fi

bin/rails db:prepare

exec "$@"
