<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "JackBuddies" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <%= stylesheet_link_tag "app", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="bg-slate-50 text-slate-900">
    <% if user_signed_in? %>
      <div class="min-h-screen md:flex">
        <aside class="w-full border-b border-slate-200 bg-white px-4 py-4 md:min-h-screen md:w-64 md:border-r md:border-b-0">
          <div class="mb-6">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Private League</p>
            <h1 class="text-xl font-bold text-slate-900">
              <%= link_to "JackBuddies", home_path(season_id: current_season&.id), class: "hover:text-emerald-700" %>
            </h1>
          </div>

          <nav class="space-y-1">
            <%= link_to "Dashboard", dashboard_path(season_id: current_season&.id), class: nav_link_class(dashboard_path) %>
            <%= link_to "Matches", matches_path(season_id: current_season&.id), class: nav_link_class(matches_path) %>
            <%= link_to "Leaderboard", leaderboard_path(season_id: current_season&.id), class: nav_link_class(leaderboard_path) %>
            <%= link_to "Users", users_path(season_id: current_season&.id), class: nav_link_class(users_path) %>
            <%= link_to "History", history_path(season_id: current_season&.id), class: nav_link_class(history_path) %>
            <% if admin? %>
              <%= link_to "Admin", admin_root_path(season_id: current_season&.id), class: nav_link_class(admin_root_path) %>
            <% end %>
          </nav>

          <div class="mt-8 rounded-xl bg-slate-100 p-3 text-sm text-slate-700">
            <p class="font-semibold"><%= current_user.name_or_email %></p>
            <p class="text-xs uppercase text-slate-500"><%= current_user.role %></p>
            <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "mt-3 w-full rounded-lg bg-slate-900 px-3 py-2 text-xs font-semibold text-white" %>
          </div>
        </aside>

        <div class="flex-1">
          <header class="sticky top-0 z-10 border-b border-slate-200 bg-white/90 px-4 py-3 backdrop-blur md:px-8">
            <div class="flex flex-wrap items-center justify-between gap-3">
              <div class="flex flex-wrap items-center gap-2">
                <% seasons_for_tabs.each do |season| %>
                  <% selected = current_season&.id == season.id %>
                  <% season_switch_params = request.query_parameters.merge(season_id: season.id) %>
                  <%= link_to season.year,
                      "#{request.path}?#{season_switch_params.to_query}",
                      class: "rounded-full px-3 py-1 text-sm font-semibold #{selected ? 'bg-slate-900 text-white' : 'bg-slate-100 text-slate-700 hover:bg-slate-200'}" %>
                <% end %>
              </div>
              <%= form_with url: request.path, method: :get, local: true, class: "flex items-center gap-2" do %>
                <%= hidden_field_tag :season_id, current_season&.id %>
                <%= text_field_tag :q, params[:q], placeholder: "Search users...", class: "w-56 rounded-xl border border-slate-200 px-3 py-2 text-sm" %>
              <% end %>
            </div>
          </header>

          <main class="px-4 py-6 md:px-8">
            <% flash.each do |type, message| %>
              <div class="mb-4 rounded-xl px-4 py-3 text-sm <%= type.to_s == 'alert' ? 'bg-rose-100 text-rose-700' : 'bg-emerald-100 text-emerald-700' %>">
                <%= message %>
              </div>
            <% end %>
            <%= yield %>
          </main>
        </div>
      </div>
    <% else %>
      <main class="mx-auto max-w-md px-6 py-12">
        <h1 class="mb-6 text-center text-3xl font-bold text-slate-900">JackBuddies</h1>
        <% flash.each do |type, message| %>
          <div class="mb-4 rounded-xl px-4 py-3 text-sm <%= type.to_s == 'alert' ? 'bg-rose-100 text-rose-700' : 'bg-emerald-100 text-emerald-700' %>">
            <%= message %>
          </div>
        <% end %>
        <%= yield %>
      </main>
    <% end %>
  </body>
</html>
