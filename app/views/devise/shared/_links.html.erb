<div class="mt-4 text-center text-sm text-slate-600">
  <% if controller_name != 'sessions' %>
    <%= link_to "Sign in", new_session_path(resource_name), class: "hover:underline" %>
  <% end %>
  <% if devise_mapping.registerable? && controller_name != 'registrations' %>
    <%= link_to "Create account", new_registration_path(resource_name), class: "ml-4 hover:underline" %>
  <% end %>
</div>
