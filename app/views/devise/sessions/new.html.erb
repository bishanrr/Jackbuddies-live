<div class="card">
  <h2 class="mb-4 text-xl font-bold">Sign in</h2>
  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-4" }) do |f| %>
    <div>
      <%= f.label :email, class: "block text-sm font-medium" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "mt-1 w-full rounded-xl border border-slate-300 px-3 py-2" %>
    </div>
    <div>
      <%= f.label :password, class: "block text-sm font-medium" %>
      <%= f.password_field :password, autocomplete: "current-password", class: "mt-1 w-full rounded-xl border border-slate-300 px-3 py-2" %>
    </div>
    <%= f.submit "Sign in", class: "btn-primary w-full" %>
  <% end %>
  <%= render "devise/shared/links" %>
</div>
