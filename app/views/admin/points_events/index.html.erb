<div class="card overflow-x-auto">
  <div class="mb-4 flex items-center justify-between">
    <h2 class="section-title">Points Ledger</h2>
    <%= link_to "Manual Adjustment", new_admin_points_event_path(season_id: current_season.id), class: "btn-primary" %>
  </div>
  <table class="min-w-full text-sm">
    <thead>
      <tr class="border-b border-slate-200 text-left text-xs uppercase tracking-wide text-slate-500">
        <th class="py-2">User</th><th class="py-2">Points</th><th class="py-2">Type</th><th class="py-2">Reason</th><th class="py-2">Status</th>
      </tr>
    </thead>
    <tbody>
      <% @events.each do |event| %>
        <tr class="border-b border-slate-100">
          <td class="py-3"><%= event.user.name_or_email %></td>
          <td class="py-3 font-semibold"><%= event.points %></td>
          <td class="py-3"><%= event.event_type %></td>
          <td class="py-3"><%= event.reason %></td>
          <td class="py-3"><%= event.voided_at? ? "Voided" : "Active" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
