<div class="card overflow-x-auto">
  <div class="mb-4 flex flex-wrap items-center justify-between gap-2">
    <h2 class="section-title">Matches - <%= current_season.year %></h2>
    <div class="flex gap-2">
      <%= link_to "New Match", new_admin_match_path(season_id: current_season.id), class: "btn-primary" %>
      <%= button_to "Recalculate Season", admin_recalculate_season_path(current_season, season_id: current_season.id), method: :post, class: "btn-secondary", data: { turbo_confirm: "Recalculate all matches for this season?" } %>
    </div>
  </div>
  <table class="min-w-full text-sm">
    <thead>
      <tr class="border-b border-slate-200 text-left text-xs uppercase tracking-wide text-slate-500">
        <th class="py-2">No.</th><th class="py-2">Match</th><th class="py-2">Time</th><th class="py-2">Stage</th><th class="py-2">Status</th><th class="py-2">Winner</th><th class="py-2"></th>
      </tr>
    </thead>
    <tbody>
      <% @matches.each do |match| %>
        <tr class="border-b border-slate-100">
          <td class="py-3"><%= match.match_no || "-" %></td>
          <td class="py-3"><%= match.home_team.short_name %> vs <%= match.away_team.short_name %></td>
          <td class="py-3"><%= match.match_datetime.strftime("%b %d %I:%M %p") %></td>
          <td class="py-3"><%= match.stage %></td>
          <td class="py-3"><%= match.status %></td>
          <td class="py-3"><%= match.winner_team&.short_name || "-" %></td>
          <td class="py-3 text-right">
            <div class="flex flex-wrap justify-end gap-2">
              <%= link_to "Edit", edit_admin_match_path(match, season_id: current_season.id), class: "btn-secondary" %>
              <%= button_to "Recalc", recalculate_admin_match_path(match, season_id: current_season.id), method: :post, class: "btn-secondary inline-flex" %>
              <%= form_with model: match, url: set_result_admin_match_path(match, season_id: current_season.id), method: :patch, local: true, class: "flex items-center gap-2" do |f| %>
                <%= f.select :winner_team_id, [[match.home_team.short_name, match.home_team_id], [match.away_team.short_name, match.away_team_id]], { include_blank: "Winner" }, class: "rounded-xl border border-slate-300 px-2 py-1 text-xs" %>
                <%= f.submit "Set", class: "btn-primary text-xs px-3 py-1.5" %>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
