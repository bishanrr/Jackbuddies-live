<div class="card">
  <h2 class="section-title"><%= @match.home_team.name %> vs <%= @match.away_team.name %></h2>
  <p class="muted mt-1"><%= @match.match_datetime.strftime("%b %d, %Y %I:%M %p") %> | <%= @match.stage.titleize %> | <%= @match.status %></p>
  <p class="mt-3 text-sm">Winner: <strong><%= @match.winner_team&.name || "Not set" %></strong></p>
  <div class="mt-4 flex gap-2">
    <%= link_to "Edit", edit_admin_match_path(@match, season_id: @match.season_id), class: "btn-secondary" %>
    <%= button_to "Recalculate", recalculate_admin_match_path(@match, season_id: @match.season_id), method: :post, class: "btn-primary" %>
  </div>
</div>
