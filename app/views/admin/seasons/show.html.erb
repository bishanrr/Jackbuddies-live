<div class="card">
  <h2 class="section-title"><%= @season.name %> (<%= @season.year %>)</h2>
  <p class="muted mt-1">Default lock minutes: <%= @season.default_lock_minutes %></p>
  <div class="mt-4 flex gap-2">
    <%= link_to "Edit", edit_admin_season_path(@season, season_id: @season.id), class: "btn-secondary" %>
    <%= link_to "Rules", edit_admin_points_rule_path(@season, season_id: @season.id), class: "btn-secondary" %>
  </div>
</div>
