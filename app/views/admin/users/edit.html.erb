<div class="card max-w-xl">
  <h2 class="section-title mb-4">Edit User</h2>
  <%= form_with model: [:admin, @user], local: true, class: "space-y-4" do |f| %>
    <div>
      <%= f.label :display_name, class: "block text-sm font-medium" %>
      <%= f.text_field :display_name, class: "mt-1 w-full rounded-xl border border-slate-300 px-3 py-2" %>
    </div>
    <div>
      <%= f.label :email, class: "block text-sm font-medium" %>
      <%= f.email_field :email, class: "mt-1 w-full rounded-xl border border-slate-300 px-3 py-2" %>
    </div>
    <div>
      <%= f.label :role, class: "block text-sm font-medium" %>
      <%= f.select :role, User.roles.keys, {}, class: "mt-1 w-full rounded-xl border border-slate-300 px-3 py-2" %>
    </div>
    <div>
      <%= f.label :status, class: "block text-sm font-medium" %>
      <%= f.select :status, User.statuses.keys, {}, class: "mt-1 w-full rounded-xl border border-slate-300 px-3 py-2" %>
    </div>
    <%= f.submit "Save", class: "btn-primary" %>
  <% end %>
</div>
