<% content_for :title, @user.name_or_email %>

<div class="grid gap-4 md:grid-cols-4">
  <div class="stat-card"><p class="muted">Total Points</p><p class="text-2xl font-bold"><%= @stats.points %></p></div>
  <div class="stat-card"><p class="muted">Accuracy</p><p class="text-2xl font-bold"><%= @stats.accuracy %>%</p></div>
  <div class="stat-card"><p class="muted">Correct Picks</p><p class="text-2xl font-bold"><%= @stats.correct_picks %></p></div>
  <div class="stat-card"><p class="muted">Rank</p><p class="text-2xl font-bold"><%= @stats.rank || "-" %></p></div>
</div>

<div class="card mt-6 overflow-x-auto">
  <h2 class="section-title mb-4">Match-by-match picks</h2>
  <table class="min-w-full text-sm">
    <thead>
      <tr class="border-b border-slate-200 text-left text-xs uppercase tracking-wide text-slate-500">
        <th class="py-2">Match</th><th class="py-2">Pick</th><th class="py-2">Winner</th><th class="py-2">Points</th>
      </tr>
    </thead>
    <tbody>
      <% @picks.each do |pick| %>
        <tr class="border-b border-slate-100">
          <td class="py-3"><%= pick.match.home_team.short_name %> vs <%= pick.match.away_team.short_name %></td>
          <td class="py-3"><%= pick.team.short_name %></td>
          <td class="py-3"><%= pick.match.winner_team&.short_name || "-" %></td>
          <td class="py-3"><%= @points_by_match_id[pick.match_id] || 0 %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
